# LoopBridge — Environment Variables
# Copy to .env and customise.
# .env is in .gitignore — never commit secrets.

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────
# Local SQLite (default)
DB_TYPE=sqlite
# DB_PATH=./loopbridge.db

# AWS RDS / Aurora (uncomment when migrating)
# DB_TYPE=pg
# DATABASE_URL=postgresql://user:pass@host:5432/loopbridge

# ─── Auth / Sessions ─────────────────────────────────────
# SESSION_TTL_MS=604800000      # 7 days
# COOKIE_NAME=lb_session
# COOKIE_SECURE=false            # set true behind HTTPS / ALB
# COOKIE_SAMESITE=lax

# ─── File Storage ────────────────────────────────────────
STORAGE_DRIVER=disk
# STORAGE_DRIVER=s3
# S3_BUCKET=loopbridge-uploads
# S3_REGION=us-east-1
# S3_PREFIX=uploads/
# CDN_BASE_URL=https://d1234.cloudfront.net

# ─── CORS ────────────────────────────────────────────────
# CORS_ORIGIN=https://loopbridge.com

# ─── Upload Limits ───────────────────────────────────────
# MAX_FILE_SIZE=52428800         # 50 MB
# MAX_FILES=10
# JSON_BODY_LIMIT=50mb
