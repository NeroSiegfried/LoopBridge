# LoopBridge — Environment Variables
# Copy to .env and customise.
# .env is in .gitignore — never commit secrets.

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────
# Local SQLite (default)
DB_TYPE=sqlite
# DB_PATH=./loopbridge.db

# AWS RDS / Aurora (uncomment when migrating)
# DB_TYPE=pg
# DATABASE_URL=postgresql://user:pass@host:5432/loopbridge

# ─── Auth / Sessions ─────────────────────────────────────
# SESSION_TTL_MS=604800000      # 7 days
# COOKIE_NAME=lb_session
# COOKIE_SECURE=false            # set true behind HTTPS / ALB
# COOKIE_SAMESITE=lax

# ─── Google OAuth ────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── OTP / Messaging (production) ───────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# OTP_FROM_EMAIL=noreply@loopbridge.com

# ─── File Storage ────────────────────────────────────────
STORAGE_DRIVER=disk
# STORAGE_DRIVER=s3
# S3_BUCKET=loopbridge-uploads
# S3_REGION=us-east-1
# S3_PREFIX=uploads/
# CDN_BASE_URL=https://d1234.cloudfront.net

# ─── Social Media Links ─────────────────────────────────
# SOCIAL_TELEGRAM=https://t.me/loopbridge
# SOCIAL_DISCORD=https://discord.gg/loopbridge
# SOCIAL_YOUTUBE=https://youtube.com/@loopbridge
# SOCIAL_TWITTER=https://x.com/loopbridge
# SOCIAL_TIKTOK=https://tiktok.com/@loopbridge
# SOCIAL_WHATSAPP=https://wa.me/loopbridge
# WHATSAPP_COMMUNITY_LINK=https://chat.whatsapp.com/invite-code

# ─── Contact Emails ─────────────────────────────────────
# CONTACT_GENERAL=hello@loopbridge.network
# CONTACT_PRESS=press@loopbridge.network
# CONTACT_SUPPORT=support@loopbridge.network

# ─── Newsletter / SMTP ──────────────────────────────────
# NEWSLETTER_FROM_EMAIL=newsletter@loopbridge.network
# NEWSLETTER_FROM_NAME=LoopBridge

# ─── CORS ────────────────────────────────────────────────
# CORS_ORIGIN=https://loopbridge.com

# ─── Upload Limits ───────────────────────────────────────
# MAX_FILE_SIZE=52428800         # 50 MB
# MAX_FILES=10
# JSON_BODY_LIMIT=50mb
